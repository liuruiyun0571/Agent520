# 后端环境配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_performance
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# 数据工厂定时任务 (默认开启)
ENABLE_CRON_JOBS=true

# 钉钉Webhook (可选)
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# 文件上传
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
